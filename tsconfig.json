{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@toolsmith/imagecore-types": [
        "../imagecore/packages/types/src/index.ts"
      ],
      "@toolsmith/imagecore-files": [
        "../imagecore/packages/files/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
